<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VoiceForge AI - 智能配音系统</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      min-height: 100vh;
      color: #fff;
      padding: 20px;
    }
    .container { max-width: 900px; margin: 0 auto; }
    
    /* 导航 */
    .nav {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-bottom: 30px;
    }
    .nav-tab {
      padding: 12px 24px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: #888;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 14px;
    }
    .nav-tab:hover { background: rgba(255, 255, 255, 0.1); }
    .nav-tab.active {
      background: linear-gradient(90deg, #00d4ff, #7c3aed);
      color: #fff;
      border-color: transparent;
    }

    /* 页面 */
    .page { display: none; }
    .page.active { display: block; }

    h1 {
      text-align: center;
      margin-bottom: 10px;
      font-size: 2rem;
      background: linear-gradient(90deg, #00d4ff, #7c3aed);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .subtitle {
      text-align: center;
      color: #888;
      margin-bottom: 40px;
    }

    /* 上传卡片 */
    .card {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      padding: 30px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      margin-bottom: 20px;
    }
    .card-title {
      font-size: 18px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .drop-zone {
      border: 2px dashed rgba(255, 255, 255, 0.2);
      border-radius: 12px;
      padding: 50px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
    }
    .drop-zone:hover, .drop-zone.drag-over {
      border-color: #00d4ff;
      background: rgba(0, 212, 255, 0.05);
    }
    .drop-zone-icon { font-size: 48px; margin-bottom: 15px; }
    .drop-zone-text { font-size: 18px; margin-bottom: 8px; }
    .drop-zone-hint { color: #888; font-size: 14px; }
    .file-input { display: none; }

    .format-info {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 20px;
    }
    .format-tag {
      background: rgba(0, 212, 255, 0.1);
      color: #00d4ff;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 14px;
    }
    .limit-info {
      text-align: center;
      color: #666;
      margin-top: 15px;
      font-size: 14px;
    }

    /* 进度条 */
    .progress-container { display: none; margin-top: 30px; }
    .progress-container.active { display: block; }
    .progress-text {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
      font-size: 14px;
    }
    .progress-bar {
      height: 8px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #00d4ff, #7c3aed);
      border-radius: 4px;
      width: 0%;
      transition: width 0.3s ease;
    }

    /* 结果展示 */
    .result { display: none; margin-top: 30px; padding: 20px; border-radius: 12px; }
    .result.active { display: block; }
    .result.success { border: 1px solid rgba(0, 255, 136, 0.3); background: rgba(0, 255, 136, 0.05); }
    .result.error { border: 1px solid rgba(255, 59, 48, 0.3); background: rgba(255, 59, 48, 0.05); }
    .result-title { font-size: 16px; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }
    .result.success .result-title { color: #00ff88; }
    .result.error .result-title { color: #ff3b30; }
    .result-details { font-size: 14px; color: #ccc; }
    .result-details p { margin-bottom: 8px; }
    .file-info {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 15px;
    }
    .file-info-item {
      background: rgba(0, 0, 0, 0.2);
      padding: 10px;
      border-radius: 8px;
    }
    .file-info-label { color: #888; font-size: 12px; margin-bottom: 4px; }
    .file-info-value { font-size: 14px; word-break: break-all; }

    /* 文件列表 */
    .file-list { margin-top: 30px; }
    .file-list h3 { margin-bottom: 15px; font-size: 16px; }
    .file-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 8px;
      margin-bottom: 8px;
    }
    .file-item-info { display: flex; align-items: center; gap: 10px; }
    .file-item-icon { font-size: 24px; }
    .file-item-name { font-size: 14px; }
    .file-item-size { font-size: 12px; color: #888; }

    /* 按钮 */
    .btn {
      padding: 8px 16px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.2s;
    }
    .btn-primary {
      background: linear-gradient(90deg, #00d4ff, #7c3aed);
      color: #fff;
    }
    .btn-primary:hover { opacity: 0.9; }
    .btn-delete { background: rgba(255, 59, 48, 0.2); color: #ff3b30; }
    .btn-delete:hover { background: rgba(255, 59, 48, 0.3); }

    /* 克隆表单 */
    .form-group { margin-bottom: 20px; }
    .form-label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      color: #aaa;
    }
    .form-input {
      width: 100%;
      padding: 12px 16px;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: #fff;
      font-size: 14px;
    }
    .form-input:focus {
      outline: none;
      border-color: #00d4ff;
    }
    .form-hint {
      margin-top: 8px;
      font-size: 12px;
      color: #666;
    }

    /* 音色列表 */
    .voice-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 15px;
      margin-top: 20px;
    }
    .voice-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 20px;
      transition: all 0.3s;
    }
    .voice-card:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(0, 212, 255, 0.3);
    }
    .voice-name {
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 8px;
    }
    .voice-desc {
      font-size: 13px;
      color: #888;
      margin-bottom: 12px;
    }
    .voice-meta {
      font-size: 12px;
      color: #666;
      margin-bottom: 15px;
    }
    .voice-actions {
      display: flex;
      gap: 10px;
    }
    .voice-tag {
      display: inline-block;
      padding: 4px 10px;
      background: rgba(0, 212, 255, 0.1);
      color: #00d4ff;
      border-radius: 12px;
      font-size: 12px;
      margin-bottom: 10px;
    }
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #666;
    }
    .empty-state-icon { font-size: 48px; margin-bottom: 15px; }

    /* 加载动画 */
    .loading {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 50%;
      border-top-color: #fff;
      animation: spin 1s ease-in-out infinite;
      margin-right: 10px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="container">
    <h1>🎙️ VoiceForge AI</h1>
    <p class="subtitle">智能AI配音系统</p>

    <!-- 导航 -->
    <div class="nav">
      <button class="nav-tab active" data-page="upload">📤 音频上传</button>
      <button class="nav-tab" data-page="clone">🎭 音色克隆</button>
      <button class="nav-tab" data-page="voices">🎵 音色库</button>
    </div>

    <!-- 上传页面 -->
    <div class="page active" id="page-upload">
      <div class="card">
        <div class="card-title">📤 上传参考音频</div>
        <div class="drop-zone" id="dropZone">
          <div class="drop-zone-icon">🎵</div>
          <div class="drop-zone-text">点击或拖拽音频文件到此处</div>
          <div class="drop-zone-hint">支持批量上传</div>
          <input type="file" id="fileInput" class="file-input" accept=".wav,.mp3">
        </div>
        <div class="format-info">
          <span class="format-tag">WAV</span>
          <span class="format-tag">MP3</span>
        </div>
        <p class="limit-info">文件大小限制：50MB</p>

        <!-- 进度条 -->
        <div class="progress-container" id="progressContainer">
          <div class="progress-text">
            <span id="progressText">上传中...</span>
            <span id="progressPercent">0%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
          </div>
        </div>

        <!-- 结果展示 -->
        <div class="result" id="result">
          <div class="result-title" id="resultTitle"></div>
          <div class="result-details" id="resultDetails"></div>
        </div>
      </div>

      <!-- 文件列表 -->
      <div class="card">
        <div class="card-title">📁 已上传文件</div>
        <div id="fileListContent">
          <div class="empty-state">
            <div class="empty-state-icon">📂</div>
            <p>暂无已上传文件</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 音色克隆页面 -->
    <div class="page" id="page-clone">
      <div class="card">
        <div class="card-title">🎭 音色克隆</div>
        
        <form id="cloneForm">
          <div class="form-group">
            <label class="form-label">音色名称 *</label>
            <input type="text" class="form-input" id="voiceName" placeholder="例如：我的自定义声音" required>
          </div>
          
          <div class="form-group">
            <label class="form-label">音色描述（可选）</label>
            <input type="text" class="form-input" id="voiceDesc" placeholder="例如：温柔的女声">
          </div>
          
          <div class="form-group">
            <label class="form-label">参考音频 *</label>
            <div class="drop-zone" id="cloneDropZone">
              <div class="drop-zone-icon">🎤</div>
              <div class="drop-zone-text">点击或拖拽参考音频</div>
              <div class="drop-zone-hint">建议使用5分钟以上的清晰音频</div>
              <input type="file" id="cloneFileInput" class="file-input" accept=".wav,.mp3">
            </div>
            <p class="form-hint">支持1-5分钟的音频，时间越长克隆效果越好</p>
          </div>

          <!-- 克隆进度 -->
          <div class="progress-container" id="cloneProgressContainer">
            <div class="progress-text">
              <span id="cloneProgressText">正在克隆音色...</span>
              <span id="cloneProgressPercent">0%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" id="cloneProgressFill"></div>
            </div>
          </div>

          <!-- 克隆结果 -->
          <div class="result" id="cloneResult">
            <div class="result-title" id="cloneResultTitle"></div>
            <div class="result-details" id="cloneResultDetails"></div>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; padding: 14px; font-size: 16px;">
            开始克隆
          </button>
        </form>
      </div>
    </div>

    <!-- 音色库页面 -->
    <div class="page" id="page-voices">
      <div class="card">
        <div class="card-title">🎵 我的音色库</div>
        <div id="voiceListContent">
          <div class="empty-state">
            <div class="empty-state-icon">🎭</div>
            <p>暂无克隆音色</p>
            <p style="margin-top: 10px;">前往"音色克隆"页面创建你的第一个音色</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ============ 导航切换 ============
    const navTabs = document.querySelectorAll('.nav-tab');
    const pages = document.querySelectorAll('.page');

    navTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const pageId = tab.dataset.page;
        
        // 更新导航状态
        navTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        
        // 更新页面显示
        pages.forEach(p => p.classList.remove('active'));
        document.getElementById('page-' + pageId).classList.add('active');
        
        // 加载对应数据
        if (pageId === 'upload') loadFileList();
        if (pageId === 'voices') loadVoiceList();
      });
    });

    // ============ 上传功能 ============
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const progressContainer = document.getElementById('progressContainer');
    const progressFill = document.getElementById('progressFill');
    const progressText = document.getElementById('progressText');
    const progressPercent = document.getElementById('progressPercent');
    const result = document.getElementById('result');
    const resultTitle = document.getElementById('resultTitle');
    const resultDetails = document.getElementById('resultDetails');
    const fileListContent = document.getElementById('fileListContent');

    // 点击上传
    dropZone.addEventListener('click', () => fileInput.click());

    // 拖拽上传
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      const files = e.dataTransfer.files;
      if (files.length > 0) handleFiles(files);
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) handleFiles(e.target.files);
    });

    function handleFiles(files) {
      const file = files[0];
      const validExtensions = ['.wav', '.mp3'];
      const ext = '.' + file.name.split('.').pop().toLowerCase();
      if (!validExtensions.includes(ext)) {
        showResult(false, '不支持的文件格式，请上传 WAV 或 MP3 格式');
        return;
      }
      if (file.size > 50 * 1024 * 1024) {
        showResult(false, '文件大小超过50MB限制');
        return;
      }
      uploadFile(file);
    }

    function uploadFile(file) {
      const formData = new FormData();
      formData.append('audio', file);

      progressContainer.classList.add('active');
      result.classList.remove('active');
      progressFill.style.width = '0%';

      const xhr = new XMLHttpRequest();

      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) {
          const percent = Math.round((e.loaded / e.total) * 100);
          progressFill.style.width = percent + '%';
          progressPercent.textContent = percent + '%';
          progressText.textContent = '上传中... ' + formatFileSize(e.loaded) + ' / ' + formatFileSize(e.total);
        }
      });

      xhr.addEventListener('load', () => {
        try {
          const response = JSON.parse(xhr.responseText);
          if (response.success) {
            showResult(true, '文件上传成功！', response.data);
            loadFileList();
          } else {
            showResult(false, response.message || '上传失败');
          }
        } catch (e) {
          showResult(false, '解析响应失败');
        }
        progressContainer.classList.remove('active');
      });

      xhr.addEventListener('error', () => {
        showResult(false, '网络错误，上传失败');
        progressContainer.classList.remove('active');
      });

      xhr.open('POST', '/api/upload');
      xhr.send(formData);
    }

    function showResult(success, message, data = null) {
      result.classList.add('active');
      result.classList.remove('success', 'error');
      result.classList.add(success ? 'success' : 'error');
      resultTitle.innerHTML = success ? '✅ ' + message : '❌ ' + message;
      if (data) {
        resultDetails.innerHTML = `
          <div class="file-info">
            <div class="file-info-item">
              <div class="file-info-label">文件名</div>
              <div class="file-info-value">${data.originalName || data.filename}</div>
            </div>
            <div class="file-info-item">
              <div class="file-info-label">文件大小</div>
              <div class="file-info-value">${formatFileSize(data.size)}</div>
            </div>
            <div class="file-info-item">
              <div class="file-info-label">格式</div>
              <div class="file-info-value">${data.mimetype}</div>
            </div>
            <div class="file-info-item">
              <div class="file-info-label">存储路径</div>
              <div class="file-info-value">${data.path}</div>
            </div>
          </div>
        `;
      } else {
        resultDetails.innerHTML = '';
      }
    }

    function loadFileList() {
      fetch('/api/uploads')
        .then(res => res.json())
        .then(data => {
          if (data.success && data.data.length > 0) {
            fileListContent.innerHTML = data.data.map(file => `
              <div class="file-item">
                <div class="file-item-info">
                  <span class="file-item-icon">🎵</span>
                  <div>
                    <div class="file-item-name">${file.filename}</div>
                    <div class="file-item-size">${formatFileSize(file.size)}</div>
                  </div>
                </div>
                <button class="btn btn-delete" onclick="deleteFile('${file.filename}')">删除</button>
              </div>
            `).join('');
          } else {
            fileListContent.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📂</div><p>暂无已上传文件</p></div>';
          }
        });
    }

    function deleteFile(filename) {
      if (!confirm('确定要删除这个文件吗？')) return;
      fetch(`/api/uploads/${filename}`, { method: 'DELETE' })
        .then(res => res.json())
        .then(data => {
          if (data.success) loadFileList();
          else alert(data.message || '删除失败');
        });
    }

    // ============ 音色克隆功能 ============
    const cloneDropZone = document.getElementById('cloneDropZone');
    const cloneFileInput = document.getElementById('cloneFileInput');
    const cloneForm = document.getElementById('cloneForm');
    const cloneProgressContainer = document.getElementById('cloneProgressContainer');
    const cloneProgressFill = document.getElementById('cloneProgressFill');
    const cloneProgressText = document.getElementById('cloneProgressText');
    const cloneProgressPercent = document.getElementById('cloneProgressPercent');
    const cloneResult = document.getElementById('cloneResult');
    const cloneResultTitle = document.getElementById('cloneResultTitle');
    const cloneResultDetails = document.getElementById('cloneResultDetails');

    let selectedCloneFile = null;

    cloneDropZone.addEventListener('click', () => cloneFileInput.click());
    
    cloneDropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      cloneDropZone.classList.add('drag-over');
    });
    cloneDropZone.addEventListener('dragleave', () => {
      cloneDropZone.classList.remove('drag-over');
    });
    cloneDropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      cloneDropZone.classList.remove('drag-over');
      if (e.dataTransfer.files.length > 0) {
        handleCloneFile(e.dataTransfer.files[0]);
      }
    });

    cloneFileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) {
        handleCloneFile(e.target.files[0]);
      }
    });

    function handleCloneFile(file) {
      const validExtensions = ['.wav', '.mp3'];
      const ext = '.' + file.name.split('.').pop().toLowerCase();
      if (!validExtensions.includes(ext)) {
        alert('不支持的文件格式，请上传 WAV 或 MP3 格式');
        return;
      }
      selectedCloneFile = file;
      cloneDropZone.querySelector('.drop-zone-text').textContent = '已选择: ' + file.name;
      cloneDropZone.querySelector('.drop-zone-hint').textContent = formatFileSize(file.size);
    }

    cloneForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = document.getElementById('voiceName').value.trim();
      const description = document.getElementById('voiceDesc').value.trim();

      if (!name) {
        alert('请输入音色名称');
        return;
      }
      if (!selectedCloneFile) {
        alert('请上传参考音频文件');
        return;
      }

      // 显示进度
      cloneProgressContainer.classList.add('active');
      cloneResult.classList.remove('active');
      cloneProgressFill.style.width = '0%';
      cloneProgressText.textContent = '正在克隆音色...';
      cloneProgressPercent.textContent = '0%';

      // 模拟进度
      let progress = 0;
      const progressInterval = setInterval(() => {
        progress += Math.random() * 15;
        if (progress > 90) progress = 90;
        cloneProgressFill.style.width = progress + '%';
        cloneProgressPercent.textContent = Math.round(progress) + '%';
      }, 200);

      const formData = new FormData();
      formData.append('audio', selectedCloneFile);
      formData.append('name', name);
      formData.append('description', description);

      try {
        const response = await fetch('/api/clone-voice', {
          method: 'POST',
          body: formData
        });
        const data = await response.json();

        clearInterval(progressInterval);
        cloneProgressFill.style.width = '100%';
        cloneProgressPercent.textContent = '100%';

        if (data.success) {
          cloneResult.classList.add('active', 'success');
          cloneResult.classList.remove('error');
          cloneResultTitle.innerHTML = '✅ 音色克隆成功！';
          cloneResultDetails.innerHTML = `
            <div class="file-info">
              <div class="file-info-item">
                <div class="file-info-label">音色ID</div>
                <div class="file-info-value">${data.data.voice_id}</div>
              </div>
              <div class="file-info-item">
                <div class="file-info-label">音色名称</div>
                <div class="file-info-value">${data.data.name}</div>
              </div>
              <div class="file-info-item">
                <div class="file-info-label">创建时间</div>
                <div class="file-info-value">${new Date(data.data.createdAt).toLocaleString('zh-CN')}</div>
              </div>
            </div>
          `;
          // 重置表单
          cloneForm.reset();
          selectedCloneFile = null;
          cloneDropZone.querySelector('.drop-zone-text').textContent = '点击或拖拽参考音频';
          cloneDropZone.querySelector('.drop-zone-hint').textContent = '建议使用5分钟以上的清晰音频';
        } else {
          cloneResult.classList.add('active', 'error');
          cloneResult.classList.remove('success');
          cloneResultTitle.innerHTML = '❌ ' + (data.message || '克隆失败');
          cloneResultDetails.innerHTML = '';
        }
      } catch (error) {
        clearInterval(progressInterval);
        cloneResult.classList.add('active', 'error');
        cloneResult.classList.remove('success');
        cloneResultTitle.innerHTML = '❌ 网络错误，克隆失败';
        cloneResultDetails.innerHTML = '';
      }

      setTimeout(() => {
        cloneProgressContainer.classList.remove('active');
      }, 1000);
    });

    // ============ 音色库功能 ============
    function loadVoiceList() {
      fetch('/api/voices')
        .then(res => res.json())
        .then(data => {
          const voiceListContent = document.getElementById('voiceListContent');
          if (data.success && data.data.length > 0) {
            voiceListContent.innerHTML = `
              <div class="voice-grid">
                ${data.data.map(voice => `
                  <div class="voice-card">
                    <span class="voice-tag">🎭 克隆音色</span>
                    <div class="voice-name">${voice.name}</div>
                    <div class="voice-desc">${voice.description || '无描述'}</div>
                    <div class="voice-meta">创建于: ${new Date(voice.createdAt).toLocaleString('zh-CN')}</div>
                    <div class="voice-actions">
                      <button class="btn btn-delete" onclick="deleteVoice('${voice.id}')">删除</button>
                    </div>
                  </div>
                `).join('')}
              </div>
            `;
          } else {
            voiceListContent.innerHTML = `
              <div class="empty-state">
                <div class="empty-state-icon">🎭</div>
                <p>暂无克隆音色</p>
                <p style="margin-top: 10px;">前往"音色克隆"页面创建你的第一个音色</p>
              </div>
            `;
          }
        });
    }

    function deleteVoice(voiceId) {
      if (!confirm('确定要删除这个音色吗？')) return;
      fetch(`/api/voices/${voiceId}`, { method: 'DELETE' })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            loadVoiceList();
          } else {
            alert(data.message || '删除失败');
          }
        });
    }

    // ============ 工具函数 ============
    function formatFileSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    // 初始加载
    loadFileList();
  </script>
</body>
</html>