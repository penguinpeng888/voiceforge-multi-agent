{
  "name": "诗词应用",
  "category": "literary",
  "description": "仙侠小说中诗词的运用技法",
  "patterns": {
    "出场诗": {
      "trigger": "重要人物首次登场",
      "structure": ["景色铺垫", "人物外貌", "身份暗示", "诗句点题"],
      "example": "青衣老者踏云而来，白发飘扬，宛若谪仙……",
      "emotion": "出场人物的气质与诗词风格匹配"
    },
    "战斗诗": {
      "trigger": "激烈战斗或决战时刻",
      "structure": ["招式描写", "天地变色", "气势对比", "结果暗示"],
      "example": "剑光如虹，直冲天际……",
      "emotion": "紧张激烈，气势磅礴"
    },
    "离别诗": {
      "trigger": "角色分离或生死离别",
      "structure": ["回忆过往", "情感抒发", "承诺或祝福", "景物渲染"],
      "example": "此去经年，不知何日再见……",
      "emotion": "凄凉不舍，眷恋难舍"
    },
    "悟道诗": {
      "trigger": "修为突破或领悟大道",
      "structure": ["困境描写", "灵感突现", "感悟道心", "境界提升"],
      "example": "山重水复疑无路，柳暗花明又一村……",
      "emotion": "豁然开朗，境界升华"
    },
    "抒情诗": {
      "trigger": "情感抒发或思念",
      "structure": ["所见景物", "引发思念", "情感外露", "结尾留白"],
      "example": "举头望明月，低头思故乡……",
      "emotion": "借景抒情，含蓄内敛"
    }
  },
  "usage_rules": [
    "诗词不宜过长，一般四句或八句",
    "要与情节和人物心境契合",
    "避免过于直白，适当留白",
    "可融入修仙元素：灵气、丹道、阵法等",
    "战斗诗要简短有力",
    "离别诗要情真意切"
  ],
  "avoid": [
    "不要堆砌华丽辞藻",
    "不要与情节脱节",
    "不要每章都加诗词",
    "不要过于直白如顺口溜"
  ]
}
