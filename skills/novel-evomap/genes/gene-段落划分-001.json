{
  "id": "gene-段落划分-001",
  "name": "段落划分方法",
  "category": "structure",
  "tags": [
    "段落",
    "结构",
    "节奏"
  ],
  "description": {
    "summary": "从忘语小说中提炼的段落划分体系",
    "core_logic": "段落是情节的最小单元，合理的划分能让阅读更流畅"
  },
  "structure": {
    "段落层级": [
      {
        "level": "微段落",
        "length": "1-3句",
        "function": "强调关键信息",
        "template": "一个动作+一个反应",
        "example": "剑光扑面而来。死亡阴影笼罩全身。"
      },
      {
        "level": "小段落",
        "length": "50-150字",
        "function": "完成一个小动作或小转折",
        "template": "动作→反应→简短心理",
        "example": "陆沉侧身躲闪。妖狼爪子擦肩而过。他反手一剑刺出。"
      },
      {
        "level": "中段落",
        "length": "150-300字",
        "function": "一个完整的叙事单元",
        "template": "场景→动作→结果",
        "example": "妖狼扑来。陆沉观察→躲避→反击→取胜"
      },
      {
        "level": "大段落",
        "length": "300-600字",
        "function": "一个完整的情节单元",
        "template": "铺垫→发展→转折→小高潮",
        "example": "发现妖狼→试探→激战→险胜→取丹"
      }
    ],
    "场景转换标记": [
      {
        "标记": "空一行",
        "适用": "同一场景内的自然过渡",
        "example": "陆沉回到洞府。猪依然在沉睡。"
      },
      {
        "标记": "时间标记",
        "适用": "时间跳跃",
        "example": "半个月后、一炷香后、第二天"
      },
      {
        "标记": "场景关键词",
        "适用": "完全不同的场景",
        "example": "回到洞府、夜幕降临、清晨"
      }
    ],
    "节奏控制": [
      {
        "模式": "紧张段落",
        "特征": "短句为主，动作密集",
        "template": "短句堆砌，省略修饰词",
        "example": "妖狼扑来。侧身。刺剑。血溅。"
      },
      {
        "模式": "缓冲段落",
        "特征": "长句为主，心理描写",
        "template": "加入感官细节、心理活动",
        "example": "他能感觉到妖狼的敌意，手心全是汗。"
      },
      {
        "模式": "转折段落",
        "特征": "悬念+意外",
        "template": "先铺垫，再反转",
        "example": "陆沉以为必死。忽然，猪醒了。"
      }
    ]
  },
  "划分原则": {
    "时间连续性": "同一时间段内不轻易分段",
    "动作完整性": "一个完整动作不分段",
    "情感完整性": "一个情绪单元不分段",
    "信息完整性": "一个完整信息不分段"
  },
  "常见问题": {
    "过短": "1-2句就分段→显得碎片化",
    "过长": "超过800字不分段→读者疲劳",
    "节奏单一": "全是中段落→缺乏变化",
    "转换突兀": "没有过渡直接分段→阅读卡顿"
  },
  "优化建议": [
    "紧张时刻用短段落加速",
    "缓冲时刻用长段落放缓",
    "每3-5段后有一次小转折",
    "每章有2-3次场景或时间转换"
  ]
}
