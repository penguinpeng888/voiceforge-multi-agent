{
  "id": "gene-title-naming-001",
  "name": "称号/封号命名体系",
  "category": "worldbuilding",
  "author": "忘语",
  "source_works": ["凡人修仙传"],
  "tags": ["称号", "封号", "身份", "尊称", "道号"],
  
  "description": {
    "summary": "忘语作品中的称号、封号、尊称命名规范",
    "core_logic": "称号是身份地位的象征，体现修真世界的等级秩序"
  },
  
  "structure": {
    "categories": [
      {
        "type": "境界称号",
        "rules": [
          "境界 + 人/者/师（如：筑基真人、金丹修士）",
          "境界 + 尊称（如：结丹宗师、元婴老怪）",
          "境界 + 职位（如：炼气弟子、筑基长老）"
        ],
        "examples": [
          "筑基真人 - 敬称",
          "结丹宗师 - 地位",
          "炼气弟子 - 身份"
        ]
      },
      {
        "type": "宗门职位",
        "rules": [
          "大小 + 职位（如：大长老、首席弟子）",
          "内/外 + 职位（如：内门弟子、外门执事）",
          "姓氏 + 职位（如：韩长老、李执事）"
        ],
        "examples": [
          "大长老 - 最高职位",
          "内门弟子 - 核心弟子",
          "传功长老 - 特定职责"
        ]
      },
      {
        "type": "道号",
        "rules": [
          "心境/追求 + 子/真人（如：玄铭子、清虚真人）",
          "功法/特点 + 子/道人（如：御灵子、玄阴道人）",
          "上古复姓 + 子（如：欧阳子、慕容真人）"
        ],
        "examples": [
          "玄铭子 - 追求",
          "御灵子 - 功法",
          "天一真人 - 上古气息"
        ]
      },
      {
        "type": "封号/荣誉称号",
        "rules": [
          "功绩 + 封号（如：护法长老、客卿供奉）",
          "地域 + 称号（如：北玄第一、南域俊杰）",
          "能力 + 称号（如：阵法宗师、炼器大宗师）"
        ],
        "examples": [
          "护法长老 - 功绩",
          "北玄第一 - 地域",
          "炼器宗师 - 能力"
        ]
      },
      {
        "type": "魔道/邪修",
        "rules": [
          "阴冷字眼 + 祖师/老祖（如：极阴祖师、血焰老祖）",
          "功法 + 名号（如：天魔解体、夺舍大法）",
          "恐怖 + 称号（如：千魂老人、万毒真人）"
        ],
        "examples": [
          "极阴祖师 - 阴冷",
          "天魔解体 - 功法",
          "千魂老人 - 恐怖"
        ]
      },
      {
        "type": "民间称呼",
        "rules": [
          "职业 + 师傅/大人（如：铁匠师傅、李大人）",
          "地域 + 称呼（如：掌柜的、店家）",
          "亲切 + 称呼（如：老人家、兄弟）"
        ],
        "examples": [
          "铁匠师傅 - 职业",
          "店家 - 通用",
          "店家 - 通用"
        ]
      }
    ]
  },
  
  "hierarchy_system": {
    "凡人界": ["凡人", "散修", "外门弟子", "内门弟子", "核心弟子", "执事", "长老", "掌门", "太上长老"],
    "筑基期": ["筑基初期", "筑基中期", "筑基后期", "筑基圆满", "筑基大圆满"],
    "结丹期": ["结丹初期", "结丹中期", "结丹后期", "结丹大圆满"],
    "元婴期": ["元婴初期", "元婴中期", "元婴后期", "元婴大圆满"],
    "化神期": ["化神初期", "化神中期", "化神后期", "化神大圆满"],
    "魔道": ["炼气散修", "筑基魔修", "结丹魔头", "元婴老怪", "化神老魔"]
  },
  
  "principles": [
    "称号要与境界/身份匹配",
    "修真界以'真人'、'道长'为敬称",
    "魔道以'老祖'、'祖师'为尊称",
    "同等级别内部有高下之分（如大长老>长老）",
    "特殊功绩可获得荣誉称号",
    "称号可传承或剥夺"
  ],
  
  "usage": {
    "when": [
      "角色出场介绍时",
      "角色进阶时更新称号",
      "角色获得荣誉时",
      "角色地位变化时"
    ],
    "how": [
      "1. 根据角色境界选择基础称号",
      "2. 根据宗门职位添加前缀",
      "3. 根据特殊功绩添加荣誉称号",
      "4. 根据地域特点添加地域前缀"
    ]
  },
  
  "created_at": "2026-02-25",
  "version": "1.0"
}
